{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Build firmware",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}/tools/vscode-build.ps1",
        "build"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": "$gcc"
    },
    {
      "label": "Flash firmware (ST-Link)",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}/tools/vscode-build.ps1",
        "flash"
      ],
      "group": "build",
      "problemMatcher": "$gcc"
    },
    {
      "label": "Probe ST-Link",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}/tools/vscode-build.ps1",
        "probe"
      ],
      "problemMatcher": []
    },
    {
      "label": "Erase chip (ST-Link)",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}/tools/vscode-build.ps1",
        "erase"
      ],
      "problemMatcher": []
    },
    {
      "label": "Reset target (ST-Link)",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}/tools/vscode-build.ps1",
        "reset"
      ],
      "problemMatcher": []
    },
    {
      "label": "Clean firmware",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}/tools/vscode-build.ps1",
        "clean"
      ],
      "problemMatcher": []
    }
  ]
}
